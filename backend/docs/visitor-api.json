{
    "openapi": "3.0.3",
    "info": {
        "title": "Visitor API",
        "description": "Endpoints to track unique visitors based on user devices.",
        "version": "1.1.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000"
        }
    ],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    },
    "paths": {
        "/api/visitors": {
            "post": {
                "summary": "Log Visitor (🌍 Global/Public)",
                "description": "Log a visitor or update their last visited time.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "device_id"
                                ],
                                "properties": {
                                    "device_id": {
                                        "type": "string",
                                        "description": "Unique device identifier UUID",
                                        "example": "123e4567-e89b-12d3-a456-426614174000"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "example": {
                                    "id": 1,
                                    "device_id": "123e4567-e89b-12d3-a456-426614174000",
                                    "device_type": "desktop",
                                    "os": "Windows",
                                    "browser": "Chrome",
                                    "device_name": "WebKit",
                                    "created_at": "2026-03-09T13:47:25.000000Z",
                                    "updated_at": "2026-03-09T13:47:25.000000Z"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "device_id is required"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/admin/visitors": {
            "get": {
                "summary": "Get Paginated Visitors (🔒 Admin Only)",
                "description": "Get detailed list of tracked visitors with pagination.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Page number for pagination",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "example": {
                                    "current_page": 1,
                                    "data": [
                                        {
                                            "id": 1,
                                            "device_id": "123e4567-e89b-12d3-a456-426614174000",
                                            "device_type": "desktop",
                                            "os": "Windows",
                                            "browser": "Chrome",
                                            "device_name": "WebKit",
                                            "created_at": "2026-03-09T13:47:25.000000Z",
                                            "updated_at": "2026-03-09T13:47:25.000000Z"
                                        }
                                    ],
                                    "first_page_url": "http://localhost:8000/api/admin/visitors?page=1",
                                    "from": 1,
                                    "last_page": 5,
                                    "last_page_url": "http://localhost:8000/api/admin/visitors?page=5",
                                    "next_page_url": "http://localhost:8000/api/admin/visitors?page=2",
                                    "path": "http://localhost:8000/api/admin/visitors",
                                    "per_page": 10,
                                    "prev_page_url": null,
                                    "to": 10,
                                    "total": 45
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Clear All Visitors (🔒 Admin Only)",
                "description": "Delete all visitor records from the database.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "All visitor records cleared successfully"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/admin/visitors/{id}": {
            "delete": {
                "summary": "Delete Single Visitor (🔒 Admin Only)",
                "description": "Delete a specific visitor record by ID.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Visitor record deleted successfully"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/admin/visitors/count": {
            "get": {
                "summary": "Get Total Visitor Count (🔒 Admin Only)",
                "description": "Get total number of unique visitors.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "example": {
                                    "data": {
                                        "total_visitors": 42
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
