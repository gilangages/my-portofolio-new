{
    "openapi": "3.0.3",
    "info": {
        "title": "Blog API",
        "description": "API untuk manajemen Blog/Artikel.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000"
        }
    ],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    },
    "paths": {
        "/api/blogs": {
            "get": {
                "summary": "Get All Published Blogs (Public)",
                "responses": {
                    "200": {
                        "description": "Berhasil mendapatkan list blog.",
                        "content": {
                            "application/json": {
                                "example": [
                                    {
                                        "id": 1,
                                        "title": "Belajar Laravel Vue",
                                        "slug": "belajar-laravel-vue",
                                        "content": "<p>Halo semua</p>",
                                        "read_time": 2,
                                        "is_published": true,
                                        "created_at": "2026-06-15T00:00:00.000000Z",
                                        "updated_at": "2026-06-15T00:00:00.000000Z"
                                    }
                                ]
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Create Blog (Admin Only)",
                "security": [{"bearerAuth": []}],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["title", "content"],
                                "properties": {
                                    "title": {"type": "string"},
                                    "content": {"type": "string", "description": "HTML string from Tiptap"},
                                    "is_published": {"type": "boolean"}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Blog Created",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Blog created successfully",
                                    "data": {
                                        "id": 1,
                                        "title": "Test Blog",
                                        "slug": "test-blog",
                                        "content": "HTML",
                                        "read_time": 1,
                                        "is_published": false
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/blogs/{slug}": {
            "get": {
                "summary": "Get Single Blog by Slug (Public)",
                "parameters": [
                    {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {"application/json": {"example": {"id": 1, "title": "Test"}}}
                    },
                    "404": {
                        "description": "Blog Not Found or Not Published"
                    }
                }
            }
        },
        "/api/admin/blogs": {
            "get": {
                "summary": "Get All Blogs including Drafts (Admin Only)",
                "security": [{"bearerAuth": []}],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/admin/blogs/{id}": {
            "get": {
                "summary": "Get Single Blog by ID for Editing (Admin Only)",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/blogs/{id}": {
            "put": {
                "summary": "Update Blog (Admin Only)",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {"type": "string"},
                                    "content": {"type": "string"},
                                    "is_published": {"type": "boolean"}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated"
                    }
                }
            },
            "delete": {
                "summary": "Delete Blog (Admin Only)",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {
                        "description": "Deleted"
                    }
                }
            }
        },
        "/api/blogs/upload-image": {
            "post": {
                "summary": "Upload Image from Tiptap (Admin Only)",
                "security": [{"bearerAuth": []}],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "required": ["image"],
                                "properties": {
                                    "image": {"type": "string", "format": "binary"}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "example": {
                                    "url": "http://localhost:8000/storage/blogs_inline/img.png"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
