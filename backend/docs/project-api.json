{
    "openapi": "3.0.3",
    "info": {
        "title": "Project API",
        "description": "Manajemen Project Portfolio.",
        "version": "1.1.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000"
        }
    ],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "ProjectStatusEnum": {
                "type": "string",
                "enum": ["completed", "in_development", "on_hold", "cancelled"],
                "description": "Project development status"
            },
            "ProjectTypeEnum": {
                "type": "string",
                "enum": ["web_development", "mobile_development", "desktop_application", "game_development"],
                "description": "Project type/category (nullable)"
            }
        }
    },
    "paths": {
        "/api/projects": {
            "get": {
                "summary": "List All Projects (🌍 Global/Public)",
                "parameters": [
                    {
                        "name": "featured",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": ["1"]
                        },
                        "description": "Filter featured projects only"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean" },
                                        "data": {
                                            "type": "array",
                                            "items": { "type": "object" }
                                        }
                                    }
                                },
                                "example": {
                                    "success": true,
                                    "data": [
                                        {
                                            "id": 1,
                                            "title": "E-Commerce Luma",
                                            "description": "A full-stack e-commerce application built with Laravel and Vue.js.",
                                            "is_featured": true,
                                            "start_date": "2025-01-10",
                                            "end_date": "2025-06-15",
                                            "status": "completed",
                                            "type": "web_development",
                                            "thumbnail_path": "projects/luma-thumbnail.jpg",
                                            "thumbnail_url": "http://localhost:8000/storage/projects/luma-thumbnail.jpg",
                                            "live_demo_link": "https://luma.abdian.dev",
                                            "repository_link": "https://github.com/abdian/luma",
                                            "team_size": 5,
                                            "role": "Fullstack Developer",
                                            "created_at": "2025-01-10T08:00:00.000000Z",
                                            "skills": [
                                                {
                                                    "id": 1,
                                                    "name": "Laravel",
                                                    "identifier": "simple-icons:laravel"
                                                },
                                                {
                                                    "id": 2,
                                                    "name": "Vue.js",
                                                    "identifier": "simple-icons:vuedotjs"
                                                }
                                            ]
                                        },
                                        {
                                            "id": 2,
                                            "title": "Personal Portfolio",
                                            "description": "My personal portfolio website to showcase my projects.",
                                            "is_featured": false,
                                            "start_date": "2025-02-01",
                                            "end_date": "2025-03-15",
                                            "status": "in_development",
                                            "type": null,
                                            "thumbnail_path": "projects/portfolio.jpg",
                                            "thumbnail_url": "http://localhost:8000/storage/projects/portfolio.jpg",
                                            "live_demo_link": "https://abdian.dev",
                                            "repository_link": "https://github.com/abdian/portfolio",
                                            "team_size": 1,
                                            "role": "Solo Developer",
                                            "created_at": "2025-02-01T10:00:00.000000Z",
                                            "skills": [
                                                {
                                                    "id": 2,
                                                    "name": "Vue.js",
                                                    "identifier": "simple-icons:vuedotjs"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Create Project (🔒 Admin Only)",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "title",
                                    "description",
                                    "thumbnail",
                                    "start_date",
                                    "end_date",
                                    "status"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "New Zenith App"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Security logging system for university project."
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2025-01-15",
                                        "description": "Project start date (YYYY-MM-DD)"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2025-06-30",
                                        "description": "Project end date (YYYY-MM-DD). Must be >= start_date"
                                    },
                                    "status": {
                                        "$ref": "#/components/schemas/ProjectStatusEnum"
                                    },
                                    "type": {
                                        "$ref": "#/components/schemas/ProjectTypeEnum"
                                    },
                                    "thumbnail": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Gambar thumbnail project (jpg/png). Max 2MB"
                                    },
                                    "is_featured": {
                                        "type": "boolean",
                                        "example": false,
                                        "description": "Pin project ke homepage"
                                    },
                                    "live_demo_link": {
                                        "type": "string",
                                        "example": "https://zenith.app"
                                    },
                                    "repository_link": {
                                        "type": "string",
                                        "example": "https://github.com/abdian/zenith"
                                    },
                                    "team_size": {
                                        "type": "integer",
                                        "example": 5,
                                        "description": "Jumlah orang yang mengerjakan proyek"
                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "Lead Backend",
                                        "description": "Peran kamu dalam proyek ini"
                                    },
                                    "tech_stack_ids[]": {
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
                                        },
                                        "description": "Array ID dari skill yang digunakan",
                                        "example": [1, 3, 5]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Project created",
                                    "data": {
                                        "id": 3,
                                        "title": "New Zenith App",
                                        "start_date": "2025-01-15T00:00:00.000000Z",
                                        "end_date": "2025-06-30T00:00:00.000000Z",
                                        "status": "in_development",
                                        "type": "web_development",
                                        "thumbnail_path": "projects/hashname.jpg",
                                        "skills": [
                                            { "id": 1, "name": "Laravel" },
                                            { "id": 3, "name": "MySQL" }
                                        ]
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "The title field is required.",
                                    "errors": {
                                        "title": ["The title field is required."],
                                        "status": ["The selected status is invalid."],
                                        "start_date": ["The start date field is required."]
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Unauthenticated."
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/projects/{id}": {
            "get": {
                "summary": "Get Single Project (🌍 Global/Public)",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "example": {
                                    "id": 1,
                                    "title": "E-Commerce Luma",
                                    "description": "Detailed description...",
                                    "is_featured": true,
                                    "start_date": "2025-01-10T00:00:00.000000Z",
                                    "end_date": "2025-06-15T00:00:00.000000Z",
                                    "status": "completed",
                                    "type": "web_development",
                                    "thumbnail_path": "projects/luma.jpg",
                                    "thumbnail_url": "http://localhost:8000/storage/projects/luma.jpg",
                                    "skills": [
                                        {
                                            "id": 1,
                                            "name": "Laravel",
                                            "identifier": "simple-icons:laravel"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "No query results for model [App\\Models\\Project] 99"
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "summary": "Update Project (🔒 Admin Only)",
                "description": "Update data project. \n\n**Note:** Karena keterbatasan PHP dengan method `PUT` pada `multipart/form-data`, Frontend disarankan menggunakan method `POST` dengan tambahan field `_method` = `PUT`.",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "title",
                                    "description",
                                    "start_date",
                                    "end_date",
                                    "status"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "E-Commerce Luma V2"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Updated description..."
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2025-01-15"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2025-07-30"
                                    },
                                    "status": {
                                        "$ref": "#/components/schemas/ProjectStatusEnum"
                                    },
                                    "type": {
                                        "$ref": "#/components/schemas/ProjectTypeEnum"
                                    },
                                    "thumbnail": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Optional: Upload file baru jika ingin mengganti thumbnail"
                                    },
                                    "is_featured": {
                                        "type": "boolean"
                                    },
                                    "live_demo_link": {
                                        "type": "string"
                                    },
                                    "repository_link": {
                                        "type": "string"
                                    },
                                    "team_size": {
                                        "type": "integer",
                                        "example": 5
                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "Lead Backend"
                                    },
                                    "tech_stack_ids[]": {
                                        "type": "array",
                                        "items": { "type": "integer" },
                                        "example": [1, 2, 4]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Project updated",
                                    "data": {
                                        "id": 1,
                                        "title": "E-Commerce Luma V2",
                                        "start_date": "2025-01-15T00:00:00.000000Z",
                                        "end_date": "2025-07-30T00:00:00.000000Z",
                                        "status": "completed",
                                        "type": "web_development",
                                        "skills": [
                                            { "id": 1, "name": "Laravel" },
                                            { "id": 2, "name": "Vue.js" },
                                            { "id": 4, "name": "Docker" }
                                        ]
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "The selected status is invalid.",
                                    "errors": {
                                        "status": ["The selected status is invalid."]
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "No query results for model [App\\Models\\Project] 99"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete Project (🔒 Admin Only)",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "integer" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Deleted",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Project deleted"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "No query results for model [App\\Models\\Project] 99"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}